    <region left="0" top="2052" width="514" height="23" color="#000000" fontSize="10" isBreakable="false">
      <text lang="cpp" fontFamily="Arial" fontSize="10">
        <content>
          <p>A combinação das equações 4 e 5, resulta na segunda equação que regje o sistema</p>
        </content>
      </text>
    </region>
    <region left="0" top="2106" width="364" height="26" color="#000000" fontSize="10">
      <math>
        <input>
          <e type="operand">θ''</e>
          <e type="operand">m</e>
