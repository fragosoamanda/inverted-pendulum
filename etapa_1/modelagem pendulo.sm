          <e type="operator" args="2">*</e>
          <e type="operand">l</e>
          <e type="operator" args="2">*</e>
          <e type="operand">sinθ</e>
          <e type="operator" args="2">*</e>
          <e type="operator" args="2">+</e>
          <e type="operand">m</e>
          <e type="operand">l</e>
