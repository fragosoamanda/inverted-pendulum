#include "stm32f4xx_hal.h"

// Definições da USART2
#define UART_BAUDRATE   57600
#define UART_TIMEOUT    1000

// Handle da USART
UART_HandleTypeDef huart2;

// Protótipos das funções
void SystemClock_Config(void);
static void MX_GPIO_Init(void);
static void MX_USART2_UART_Init(void);

// Mensagem a ser enviada
const char msg[] = "Hello from STM32F401CC!\r\n";


// Função de tratamento de erro
void Error_Handler(void)
{
    while (1)
    {
        // Pisca LED ou fica em loop infinito
    }
}

int main(void)
{
    // Reset do HAL
    HAL_Init();

    // Configurar clock do sistema (geralmente 84 MHz para este MCU)
    SystemClock_Config();

    // Inicializar GPIO e USART2
    MX_GPIO_Init();
    MX_USART2_UART_Init();

    // Loop principal
    // while (1)
    // {
    //     // Envia a mensagem via USART2
    //     HAL_UART_Transmit(&huart2, (uint8_t*)msg, sizeof(msg) - 1, UART_TIMEOUT);

    //     // Aguarda 1 segundo
    //     HAL_Delay(1000);
    // }

	while (1) {
		uint8_t test = 'U';
		HAL_UART_Transmit(&huart2, &test, 1, 100);
		HAL_Delay(1);
	}
}

// Configuração do clock do sistema (HSI ou HSE conforme necessitar)
void SystemClock_Config(void)
{
    RCC_OscInitTypeDef RCC_OscInitStruct = {0};
    RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

    // Habilita HSE (cristal externo de 25 MHz)
    RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSE;
    RCC_OscInitStruct.HSEState = RCC_HSE_ON;
    RCC_OscInitStruct.PLL.PLLState = RCC_PLL_ON;
    RCC_OscInitStruct.PLL.PLLSource = RCC_PLLSOURCE_HSE;
    RCC_OscInitStruct.PLL.PLLM = 25;        // 25 MHz / 25 = 1 MHz
    RCC_OscInitStruct.PLL.PLLN = 336;       // 1 MHz * 336 = 336 MHz
    RCC_OscInitStruct.PLL.PLLP = RCC_PLLP_DIV4; // 336/4 = 84 MHz (SYSCLK)
    RCC_OscInitStruct.PLL.PLLQ = 7;         // 48 MHz para USB
    HAL_RCC_OscConfig(&RCC_OscInitStruct);

    // Seleciona PLL como fonte do clock do sistema
    RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK | RCC_CLOCKTYPE_SYSCLK
                                  | RCC_CLOCKTYPE_PCLK1 | RCC_CLOCKTYPE_PCLK2;
    RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_PLLCLK;
    RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;   // HCLK = 84 MHz
    RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV2;    // APB1 = 42 MHz
    RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;    // APB2 = 84 MHz
    HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_2);
}

// Configuração dos pinos GPIO para USART2 (PA2 = TX, PA3 = RX)
static void MX_GPIO_Init(void)
{
    GPIO_InitTypeDef GPIO_InitStruct = {0};

    // Habilitar clock do GPIOA
    __HAL_RCC_GPIOA_CLK_ENABLE();

    // Configurar PA2 como AF (Alternate Function) para USART2_TX
    GPIO_InitStruct.Pin = GPIO_PIN_2;
    GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
    GPIO_InitStruct.Pull = GPIO_NOPULL;
    GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
    GPIO_InitStruct.Alternate = GPIO_AF7_USART2;  // AF7 para USART2
    HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

    // Configurar PA3 como AF para USART2_RX
    GPIO_InitStruct.Pin = GPIO_PIN_3;
    GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
    GPIO_InitStruct.Alternate = GPIO_AF7_USART2;
    HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);
}

// Configuração da USART2
static void MX_USART2_UART_Init(void)
{
    huart2.Instance = USART2;
    huart2.Init.BaudRate = UART_BAUDRATE;
    huart2.Init.WordLength = UART_WORDLENGTH_8B;
    huart2.Init.StopBits = UART_STOPBITS_1;
    huart2.Init.Parity = UART_PARITY_NONE;
    huart2.Init.Mode = UART_MODE_TX_RX;   // Transmissão e recepção habilitadas
    huart2.Init.HwFlowCtl = UART_HWCONTROL_NONE;
    huart2.Init.OverSampling = UART_OVERSAMPLING_16;

    // Habilitar clock da USART2
    __HAL_RCC_USART2_CLK_ENABLE();

    if (HAL_UART_Init(&huart2) != HAL_OK)
    {
        // Tratamento de erro (pode parar aqui ou colocar um loop)
        Error_Handler();
    }
}
